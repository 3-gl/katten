{
    "app-id": "org.kde.katten",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.6",
    "sdk": "org.kde.Sdk",
    "command": "katten.py",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=wayland",
        "--socket=x11",
        "--filesystem=xdg-config/katten:create",
        "--filesystem=~/.local/share/katten:create",
        "--filesystem=~/.local/share/icons:create",
        "--filesystem=~/.local/share/krunner:create",
        "--filesystem=~/.local/share/dbus-1:create",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.kde.krunner1",
        "--dbus=session",
        "--own-name=org.kde.katten"
    ],
    "modules": [
        {
            "name": "python3-markdown",
            "buildsystem": "simple",
            "build-commands": ["pip3 install --prefix=/app markdown"],
            "sources": [
                {"type": "pip", "name": "markdown"}
            ]
        },
        {
            "name": "python3-pyqt6",
            "buildsystem": "simple", 
            "build-commands": ["pip3 install --prefix=/app PyQt6"],
            "sources": [
                {"type": "pip", "name": "PyQt6"}
            ]
        },
        {
            "name": "katten",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 katten.py /app/share/katten/katten.py",
                "install -Dm755 quicklook_panel.py /app/share/katten/quicklook_panel.py",
                "install -Dm755 first_run_panel.py /app/share/katten/first_run_panel.py",
                "install -Dm644 katten-icon.svg /app/share/katten/katten-icon.svg",
                "install -Dm644 katten-icon.svg /app/share/icons/hicolor/scalable/apps/katten-icon.svg",
                "install -Dm644 katten.desktop /app/share/krunner/dbusplugins/katten.desktop",
                "install -Dm644 org.kde.katten.service /app/share/dbus-1/services/org.kde.katten.service",
                "install -Dm755 katten-config /app/bin/katten-config",
                "install -Dm644 org.kde.katten.metainfo.xml /app/share/metainfo/org.kde.katten.metainfo.xml"
            ],
            "sources": [
                {
                    "type": "file",
                    "path": "katten.py"
                },
                {
                    "type": "file",
                    "path": "quicklook_panel.py"
                },
                {
                    "type": "file",
                    "path": "first_run_panel.py"
                },
                {
                    "type": "file",
                    "path": "katten-config"
                },
                {
                    "type": "file",
                    "path": "katten.desktop"
                },
                {
                    "type": "file",
                    "path": "org.kde.katten.service"
                },
                {
                    "type": "file",
                    "path": "katten-icon.svg"
                },
                {
                    "type": "file",
                    "path": "org.kde.katten.metainfo.xml"
                }
            ]
        }
    ],
    "description": "KRunner plugin for Mistral AI Vibe that allows you to send prompts to Mistral AI directly from KRunner and view responses in a preview panel with full markdown rendering.",
    "metadata": {
        "name": "Katten",
        "summary": "Mistral AI Vibe integration for KRunner",
        "description": "Katten is a KDE Plasma 6 KRunner plugin that allows you to send prompts to Mistral AI's Vibe service directly from KRunner (Alt+Space). It features a preview panel with full markdown rendering support for tables, code blocks, lists, and more.",
        "tags": ["kde", "plasma", "krunner", "ai", "mistral", "lechat", "chat"],
        "license": "GPL-3.0+",
        "url": {
            "homepage": "https://github.com/emilio-longoria/katten"
        }
    },
    "required-versions": {
        "org.kde.Platform": "6.6",
        "org.kde.Sdk": "6.6"
    }
}
