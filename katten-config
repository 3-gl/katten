import json
import time
import threading
import subprocess
from pathlib import Path

# Import KWallet functions from katten module
try:
    # Add the current directory to path so we can import katten
    sys.path.insert(0, str(Path(__file__).parent))
    from katten import save_api_key
    KWALLET_AVAILABLE = True
except ImportError:
    KWALLET_AVAILABLE = False
from urllib.request import Request, urlopen
from urllib.error import HTTPError, URLError

CONFIG_DIR  = Path.home() / ".config" / "katten"
CONFIG_FILE = CONFIG_DIR / "config.json"
PLUGIN_DIR  = Path.home() / ".local" / "share" / "katten"

DEFAULT_KEYWORDS = ["katten", "lechat", "lc", "mistral", "vibe", "mv"]

# ── ANSI colours ────────────────────────────────────────────────────────────
R  = "\033[0;31m"
G  = "\033[0;32m"
Y  = "\033[1;33m"
B  = "\033[0;34m"
C  = "\033[0;36m"
NC = "\033[0m"
BOLD = "\033[1m"


def load_config():
    if CONFIG_FILE.exists():
        try:
            with open(CONFIG_FILE) as f:
                return json.load(f)
        except (json.JSONDecodeError, IOError):
            pass
    return {
        "api_key":           "",
        "default_agent_id":  None,
        "web_search_enabled": True,
        "websearch_agent_id": None,
        "keywords":          DEFAULT_KEYWORDS.copy(),
    }


def save_config(config):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)
    os.chmod(CONFIG_FILE, 0o600)
    print(f"{G}[OK]{NC} Configuration saved to: {CONFIG_FILE}")


# ── Terminal spinner ─────────────────────────────────────────────────────────

class Spinner:
    """
    Displays an animated spinner in the terminal while a task is running.
    Usage:
        with Spinner("Testing API key"):
            time.sleep(3)
    """
    FRAMES = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]

    def __init__(self, message: str):
        self._message  = message
        self._stop_evt = threading.Event()
        self._thread   = threading.Thread(target=self._spin, daemon=True)

    def _spin(self):
        i = 0
        while not self._stop_evt.is_set():
            frame = self.FRAMES[i % len(self.FRAMES)]
            print(f"\r   {C}{frame}{NC} {self._message}…", end="", flush=True)
            time.sleep(0.08)
            i += 1

    def __enter__(self):
        self._thread.start()
        return self

    def __exit__(self, *_):
        self._stop_evt.set()
        self._thread.join()
        # Clear the spinner line
        print(f"\r{' ' * (len(self._message) + 12)}\r", end="", flush=True)


# ── API key validation ───────────────────────────────────────────────────────

TEST_PROMPT = (
    "This prompt is a test to verify the correct connection to Mistral AI. "
    "Reply correctsetup if you are ready to receive more prompts. "
    "Do not reply anything other than correctsetup or error."
)


def test_api_key(api_key: str) -> tuple[bool, str]:
    """
    Send a test prompt to Mistral.  Returns (success, error_message).
    success is True only when the model replies exactly 'correctsetup'.
    """
    url = "https://api.mistral.ai/v1/chat/completions"
    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type":  "application/json",
        "Accept":        "application/json",
    }
    payload = {
        "model":    "mistral-small-latest",
        "messages": [{"role": "user", "content": TEST_PROMPT}],
    }
    try:
        req = Request(url, method="POST", headers=headers)
        req.data = json.dumps(payload).encode()
        with urlopen(req, timeout=30) as resp:
            data    = json.loads(resp.read().decode())
            choices = data.get("choices", [])
            if not choices:
                return False, "Empty response from API"
            reply = choices[0].get("message", {}).get("content", "").strip().lower()
            if reply == "correctsetup":
                return True, ""
            return False, f"Unexpected reply: '{reply[:80]}'"
    except HTTPError as e:
        body = e.read().decode() if e.fp else str(e)
        try:
            msg = json.loads(body).get("message", body)
        except Exception:
            msg = body
        return False, f"HTTP {e.code}: {msg[:200]}"
    except URLError as e:
        return False, f"Network error: {e.reason}"
    except Exception as e:
        return False, str(e)


def prompt_api_key() -> str | None:
    """
    Interactively prompt for an API key, test it, and retry or cancel as needed.
    Returns the validated API key, or None if the user cancelled.
    """
    config = load_config()

    while True:
        print()
        current = config.get("api_key", "")
        masked  = (f"{current[:8]}…{current[-4:]}"
                   if len(current) > 12 else "(not set)")
        print(f"   Current key : {Y}{masked}{NC}")
        print(f"   Get a key   : {B}https://console.mistral.ai/api-keys{NC}")
        print(f"   Tip         : Your key starts with a long string of letters")
        print(f"                 and digits. Never share it with others.")
        print()

        new_key = input("   Enter Mistral API key (or Enter to keep current): ").strip()
        key_to_test = new_key if new_key else current

        if not key_to_test:
            print(f"   {Y}No key entered.{NC}")
            return _offer_cancel_or_retry()

        print()
        ok = False
        err = ""
        with Spinner("Testing API key"):
            ok, err = test_api_key(key_to_test)

        if ok:
            print(f"   {G}[OK]{NC} API key verified — Vibe is ready!")
            print()
            return key_to_test
        else:
            print(f"   {R}[FAIL]{NC} API key test failed.")
            print(f"          Reason : {err}")
            print()
            print(f"   Possible causes:")
            print(f"     1. The key is incorrect — double-check at {B}console.mistral.ai/api-keys{NC}")
            print(f"     2. The key has no remaining credits")
            print(f"     3. Mistral's servers may be experiencing an outage")
            print(f"        (check {B}https://status.mistral.ai{NC})")
            print()

            choice = _offer_retry_or_cancel()
            if choice == "retry":
                continue
            elif choice == "cancel":
                return None
            else:
                return None


def _offer_retry_or_cancel() -> str:
    """Returns 'retry' or 'cancel'."""
    while True:
        ans = input("   [R]etry with a new key  /  [C]ancel setup? ").strip().lower()
        if ans in ("r", "retry"):
            return "retry"
        if ans in ("c", "cancel"):
            return "cancel"
        print("   Please type R or C.")


def _offer_cancel_or_retry() -> str | None:
    while True:
        ans = input("   [R]etry  /  [C]ancel? ").strip().lower()
        if ans in ("r", "retry"):
            return None       # caller re-enters the loop
        if ans in ("c", "cancel"):
            return None
        print("   Please type R or C.")


# ── Uninstall ────────────────────────────────────────────────────────────────

def offer_uninstall():
    print()
    ans = input(f"   {Y}Would you like to uninstall Katten? (y/n): {NC}").strip().lower()
    if ans != "y":
        print("   Uninstall cancelled. Goodbye.")
        sys.exit(0)

    print()
    print(f"   {B}Uninstalling…{NC}")

    uninstall_sh = Path(__file__).parent / "uninstall.sh"
    local_uninstall = PLUGIN_DIR / "uninstall.sh"
    script = uninstall_sh if uninstall_sh.exists() else local_uninstall

    if script.exists():
        subprocess.run(["bash", str(script)])
    else:
        # Manual cleanup
        import shutil
        paths = [
            PLUGIN_DIR,
            CONFIG_DIR,
            Path.home() / ".local/share/krunner/dbusplugins/katten.desktop",
            Path.home() / ".local/share/dbus-1/services/org.kde.katten.service",
            Path.home() / ".local/bin/katten-config",
            Path.home() / ".local/share/icons/hicolor/128x128/apps/katten-icon.png",
            Path.home() / ".local/share/icons/hicolor/scalable/apps/katten-icon.svg",
        ]
        for p in paths:
            try:
                if p.is_dir():
                    shutil.rmtree(p)
                elif p.exists():
                    p.unlink()
                print(f"   {G}Removed:{NC} {p}")
            except Exception as e:
                print(f"   {Y}Could not remove {p}:{NC} {e}")

        # Restart KRunner
        subprocess.run(["kquitapp6", "krunner"],  capture_output=True)
        subprocess.run(["pkill", "-f", "katten.py"], capture_output=True)

    print()
    print(f"   {G}Plugin uninstalled.{NC} Goodbye.")
    sys.exit(0)


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    print()
    print(f"{BOLD}{'=' * 60}{NC}")
    print(f"{BOLD}  Katten - Configuration{NC}")
    print(f"{BOLD}{'=' * 60}{NC}")
    print()

    config = load_config()

    # ── 1. API KEY ──────────────────────────────────────────────────────────
    print(f"{BOLD}1. API KEY{NC}")
    print(f"   Your Mistral API key links this plugin to your account.")

    validated_key = prompt_api_key()

    if validated_key is None:
        # Test failed and user chose to cancel
        print()
        print(f"   {Y}Setup cancelled.{NC}")
        offer_uninstall()
        sys.exit(0)

    # Save API key using KWallet or config file
    if KWALLET_AVAILABLE and validated_key:
        try:
            if not save_api_key(validated_key):
                # User cancelled, don't save to config either
                print(f"   {Y}Setup cancelled.{NC}")
                offer_uninstall()
                sys.exit(0)
        except Exception:
            # Fall back to config file
            config["api_key"] = validated_key
    else:
        config["api_key"] = validated_key
    print()

    # ── 2. TRIGGER KEYWORDS ─────────────────────────────────────────────────
    print(f"{BOLD}2. TRIGGER KEYWORDS{NC}")
    current_kw = config.get("keywords", DEFAULT_KEYWORDS)
    print(f"   Current  : {', '.join(current_kw)}")
    print(f"   These are the words you type in KRunner to activate Katten.")
    print()
    print(f"   [1] Keep current  [2] Reset to defaults  [3] Set custom")
    print()
    kw_choice = input("   Choice (1/2/3, or Enter to keep): ").strip()

    if kw_choice == "2":
        config["keywords"] = DEFAULT_KEYWORDS.copy()
        print(f"   {G}[OK]{NC} Keywords reset to: {', '.join(DEFAULT_KEYWORDS)}")
    elif kw_choice == "3":
        print()
        custom = input("   Enter keywords separated by commas: ").strip()
        kws = [k.strip().lower() for k in custom.split(",") if k.strip()]
        if kws:
            config["keywords"] = kws
            print(f"   {G}[OK]{NC} Keywords set to: {', '.join(kws)}")
        else:
            print(f"   {Y}No valid keywords, keeping current.{NC}")
    else:
        print(f"   {G}[OK]{NC} Keywords unchanged.")
    print()

    # ── 3. WEB SEARCH ───────────────────────────────────────────────────────
    print(f"{BOLD}3. WEB SEARCH{NC}")
    current_web = config.get("web_search_enabled", True)
    print(f"   Currently : {'Enabled' if current_web else 'Disabled'}")
    print(f"   When enabled, Katten searches the web for up-to-date answers.")
    print()
    ws = input("   Enable web search by default? (y/n, Enter to keep): ").strip().lower()
    if ws == "y":
        config["web_search_enabled"] = True
        print(f"   {G}[OK]{NC} Web search enabled.")
    elif ws == "n":
        config["web_search_enabled"] = False
        print(f"   {G}[OK]{NC} Web search disabled.")
    else:
        print(f"   {G}[OK]{NC} Unchanged.")
    print()

    # ── 4. OPTIONAL: clear caches ───────────────────────────────────────────
    if config.get("default_agent_id"):
        print(f"{BOLD}4. DEFAULT AGENT{NC}")
        print(f"   Current agent ID: {config['default_agent_id']}")
        if input("   Clear default agent? (y/n): ").strip().lower() == "y":
            config["default_agent_id"] = None
            print(f"   {G}[OK]{NC} Default agent cleared.")
        print()

    if config.get("websearch_agent_id"):
        print(f"{BOLD}5. WEB SEARCH AGENT CACHE{NC}")
        print(f"   Cached agent ID: {config['websearch_agent_id']}")
        if input("   Clear cache? (y/n): ").strip().lower() == "y":
            config["websearch_agent_id"] = None
            print(f"   {G}[OK]{NC} Cache cleared — a new agent will be created next use.")
        print()

    # ── Save ─────────────────────────────────────────────────────────────────
    save_config(config)
    print()

    # ── Summary ──────────────────────────────────────────────────────────────
    keywords   = config.get("keywords", DEFAULT_KEYWORDS)
    primary_kw = keywords[0] if keywords else "lechat"

    print(f"{BOLD}{'=' * 60}{NC}")
    print(f"{G}{BOLD}  Configuration complete!{NC}")
    print(f"{BOLD}{'=' * 60}{NC}")
    print()
    print(f"   Usage in KRunner ({B}Alt+Space{NC}):")
    print()
    print(f"   {Y}{primary_kw} <question>{NC}           Ask Katten")
    print(f"   {Y}{primary_kw} web <question>{NC}       Force web search")
    print(f"   {Y}{primary_kw} noweb <question>{NC}     Disable web search")
    print(f"   {Y}{primary_kw} agents{NC}               List API-created agents")
    print(f"   {Y}{primary_kw} clear agent{NC}          Clear the default agent")
    print()
    print(f"   All trigger keywords : {', '.join(keywords)}")
    print(f"   (You can use any of these to activate Katten)")
    print()
    print(f"   To restart KRunner:")
    print(f"   {Y}kquitapp6 krunner && kstart krunner{NC}")
    print()


if __name__ == "__main__":
    main()
