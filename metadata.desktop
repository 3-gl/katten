[Desktop Entry]
Type=Service
X-KDE-ServiceTypes=Plasma/Runner
X-KDE-Library=plasma_runner_katten

Name=Katten (Mistral AI)
Comment=Send prompts to Mistral AI and get responses in KRunner - unofficial Vibe plugin
Icon=katten-icon
Category=KDE
Category=Plasma
Category=KRunner
Category=Utility
Category=AI

X-KDE-PluginInfo-Name=org.kde.katten
X-KDE-PluginInfo-Category=KRunner
X-KDE-PluginInfo-Version=0.4.1
X-KDE-PluginInfo-Website=https://github.com/emilio-longoria/katten
X-KDE-PluginInfo-Author=Emilio Longoria
X-KDE-PluginInfo-License=GPL-3.0+
X-KDE-PluginInfo-EnabledByDefault=true

X-Plasma-API=DBus
X-Plasma-DBusRunner-Service=org.kde.katten
X-Plasma-DBusRunner-Path=/katten

X-Plasma-Runner-Min-Letter-Count=2
X-Plasma-Runner-Syntaxes=katten :q:,lechat :q:,lc :q:,mistral :q:,vibe :q:,mv :q:,katten web :q:,katten agents
X-Plasma-Runner-Syntax-Descriptions=Ask Katten a question,Alternative keyword,Short alias,Alternative keyword,Vibe keyword,Short Vibe alias,Force web search,List custom agents
